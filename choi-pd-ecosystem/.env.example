# Database (LibSQL/Turso)
DATABASE_URL=file:./data/database.db
DATABASE_AUTH_TOKEN=

# JWT Authentication (REQUIRED for production)
JWT_SECRET=your-secret-key-here-change-in-production

# Google OAuth (회원 가입/로그인)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3011/api/auth/google/callback

# TowninGraph OAuth (외부 연동)
TOWNINGRAPH_CLIENT_ID=
TOWNINGRAPH_CLIENT_SECRET=
TOWNINGRAPH_OAUTH_URL=https://towningraph.com/oauth
TOWNINGRAPH_REDIRECT_URI=http://localhost:3011/api/auth/towningraph/callback

# Admin Access Control (쉼표로 구분)
ADMIN_ALLOWED_EMAILS=admin@example.com

# Base Domain (서브도메인 라우팅)
BASE_DOMAIN=localhost:3011

# Encryption Key (for sensitive data)
ENCRYPTION_KEY=your-encryption-key-here

# SocialDoctors social-pulse 연동 (SNS 발행 허브)
SOCIAL_PULSE_API_URL=https://socialdoctors.co.kr
SOCIAL_PULSE_API_KEY=your-social-pulse-api-key

# LinkedIn OAuth (소셜 미디어 연동)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# 네이버 서치어드바이저 사이트 인증코드
NAVER_SITE_VERIFICATION=

# OpenAI (Chat AI)
OPENAI_API_KEY=your-openai-api-key

# Resend (이메일 발송)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@impd.com
RESEND_FROM_NAME=imPD

# Obsidian Memory Vault 경로
OBSIDIAN_VAULT_PATH=./data/obsidian-vault

# ─── Deployment (Docker / Coolify) ───
# DOCKER_BUILD=true 시 next.config.js에서 output: 'standalone' 활성화
DOCKER_BUILD=true
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Clerk Authentication (관리자 스크립트용)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Admin Scripts (scripts/create-admin.js, scripts/reset-admin.js)
ADMIN_EMAIL=admin@choipd.com
ADMIN_PASSWORD=your-strong-password-here

# Stripe 결제 연동 (ISS-010)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
