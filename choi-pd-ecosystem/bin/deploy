#!/usr/bin/env bash
# ============================================================
# imPD - Vultr 배포 스크립트
# 서버: 158.247.235.31 (Vultr ICN)
# URL: https://impd.158.247.235.31.nip.io
# 홍보: https://impd.158.247.235.31.nip.io/chopd
# ============================================================
set -e

SERVER="root@158.247.235.31"
APP_NAME="impd"
REMOTE_DIR="/opt/impd"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
DOMAIN="impd.158.247.235.31.nip.io"

# 색상 출력
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[OK]${NC} $1"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }

START_TIME=$(date +%s)

# ─── 옵션 파싱 ─────────────────────────────────────────────
FULL_BUILD=false
RESTART_ONLY=false
for arg in "$@"; do
  case $arg in
    --full)    FULL_BUILD=true ;;
    --restart) RESTART_ONLY=true ;;
  esac
done

# ─── 재시작만 ──────────────────────────────────────────────
if [ "$RESTART_ONLY" = true ]; then
  info "컨테이너 재시작만 진행..."
  ssh -o StrictHostKeyChecking=no $SERVER \
    "docker restart $APP_NAME && echo '✅ 재시작 완료'"
  exit 0
fi

# ─── STEP 1: 소스 전송 ────────────────────────────────────
info "📦 STEP 1/3: 소스 전송 중..."

# choi-pd-ecosystem 디렉토리의 소스만 전송
ssh -o StrictHostKeyChecking=no $SERVER "mkdir -p $REMOTE_DIR"
tar -c \
  --exclude='node_modules' \
  --exclude='.next' \
  --exclude='data' \
  --exclude='.git' \
  --exclude='._*' \
  -f - . | ssh -o StrictHostKeyChecking=no $SERVER "tar -xC $REMOTE_DIR"

success "소스 전송 완료"

# ─── STEP 2: Docker 빌드 ──────────────────────────────────
info "🔨 STEP 2/3: Docker 빌드 중..."

if [ "$FULL_BUILD" = true ]; then
  warn "전체 재빌드 모드 (--full)"
  BUILD_OPTS="--no-cache"
else
  BUILD_OPTS=""
fi

BUILD_RESULT=$(ssh -o StrictHostKeyChecking=no $SERVER \
  "cd $REMOTE_DIR && docker build --platform linux/amd64 $BUILD_OPTS -t ${APP_NAME}:latest -t ${APP_NAME}:${TIMESTAMP} . 2>&1")
echo "$BUILD_RESULT" | grep -E "^#|DONE|ERROR|Step|cached|CACHED|error" | head -30

if echo "$BUILD_RESULT" | grep -qi "error"; then
  warn "빌드 경고/오류 감지"
fi

success "빌드 완료"

# ─── STEP 3: 컨테이너 배포 ─────────────────────────────────
info "🚀 STEP 3/3: 컨테이너 배포 중..."
ssh -o StrictHostKeyChecking=no $SERVER << DEPLOY_EOF
  set -e

  # 기존 컨테이너 중지
  docker stop $APP_NAME 2>/dev/null || true
  docker rm   $APP_NAME 2>/dev/null || true

  # 새 컨테이너 시작
  docker run -d \
    --name $APP_NAME \
    --restart unless-stopped \
    --network kamal \
    --memory=2g \
    --memory-swap=4g \
    -p 3300:3000 \
    -e NODE_ENV=production \
    -e PORT=3000 \
    -e DATABASE_URL=file:./data/database.db \
    -e JWT_SECRET=impd-production-jwt-secret-$(openssl rand -hex 8) \
    -e ENCRYPTION_KEY=impd-production-encryption-$(openssl rand -hex 8) \
    -e BASE_DOMAIN=$DOMAIN \
    -e TZ=Asia/Seoul \
    -v ${APP_NAME}_data:/app/data \
    -v ${APP_NAME}_uploads:/app/public/uploads \
    ${APP_NAME}:latest

  # 헬스체크 (최대 90초 — Next.js 첫 빌드 시간 고려)
  echo "헬스체크 대기 중..."
  HEALTH_OK=false
  for i in \$(seq 1 18); do
    HTTP_STATUS=\$(docker exec $APP_NAME curl -s -o /dev/null -w "%{http_code}" http://localhost:3000/api/health 2>/dev/null || echo "000")
    CONTAINER_STATUS=\$(docker inspect $APP_NAME --format "{{.State.Status}}" 2>/dev/null || echo "unknown")
    echo "  [\$i/18] 컨테이너: \$CONTAINER_STATUS, HTTP: \$HTTP_STATUS"
    if [ "\$HTTP_STATUS" = "200" ]; then
      HEALTH_OK=true
      echo "✅ 헬스체크 통과 (\${i}회차)"
      break
    fi
    sleep 5
  done
  if [ "\$HEALTH_OK" = false ]; then
    echo "⚠️  헬스체크 미통과 — 최근 로그:"
    docker logs $APP_NAME --tail 30
  fi

  # kamal-proxy 등록
  APP_IP=\$(docker inspect $APP_NAME --format "{{.NetworkSettings.Networks.kamal.IPAddress}}" 2>/dev/null || echo "")
  if [ -n "\$APP_IP" ]; then
    echo "kamal-proxy 등록 중... (target: \$APP_IP:3000)"
    docker exec kamal-proxy kamal-proxy deploy $APP_NAME \
      --host "$DOMAIN" \
      --target "\$APP_IP:3000" \
      --target-timeout 90s 2>&1 || true
    echo "✅ kamal-proxy 등록 완료"
  else
    echo "⚠️  kamal 네트워크 IP를 가져올 수 없습니다"
    echo "    직접 접속: http://158.247.235.31:3300"
  fi
DEPLOY_EOF

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

echo ""
success "=========================================="
success "✅ 배포 완료! 소요시간: ${ELAPSED}초"
success "🌐 https://$DOMAIN"
success "🏠 https://$DOMAIN/chopd"
success "🔧 http://158.247.235.31:3300 (직접)"
success "=========================================="

# 오래된 이미지 정리 (최근 3개만 유지)
ssh -o StrictHostKeyChecking=no $SERVER \
  "docker images $APP_NAME --format '{{.ID}}' | tail -n +4 | xargs docker rmi 2>/dev/null || true"
