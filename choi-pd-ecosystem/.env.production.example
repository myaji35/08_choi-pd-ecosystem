# ==============================================
# imPD Platform - Production Environment Config
# ==============================================
# Copy this file to .env.local for production deployment

# Database (LibSQL/Turso - Production)
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# JWT Authentication
JWT_SECRET=your-secure-jwt-secret-min-32-chars

# Google OAuth (회원 가입/로그인)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://impd.townin.net/api/auth/google/callback

# TowninGraph OAuth (외부 연동)
TOWNINGRAPH_CLIENT_ID=your-towningraph-client-id
TOWNINGRAPH_CLIENT_SECRET=your-towningraph-client-secret
TOWNINGRAPH_OAUTH_URL=https://towningraph.com/oauth
TOWNINGRAPH_REDIRECT_URI=https://impd.townin.net/api/auth/towningraph/callback

# Admin Access Control (쉼표로 구분)
ADMIN_ALLOWED_EMAILS=admin@impd.com

# Base Domain (서브도메인 라우팅)
BASE_DOMAIN=impd.townin.net

# Encryption Key (for sensitive data like SNS tokens)
ENCRYPTION_KEY=your-32-byte-encryption-key-base64

# Payment Gateways
# TossPayments
TOSS_CLIENT_KEY=live_ck_your_client_key
TOSS_SECRET_KEY=live_sk_your_secret_key

# Stripe (Optional for global expansion)
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service
# Resend (Recommended)
RESEND_API_KEY=re_your_api_key

# SendGrid (Alternative)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# File Storage
# Google Cloud Storage
GCS_PROJECT_ID=your-gcs-project-id
GCS_BUCKET_NAME=your-bucket-name
GCS_KEY_FILE=./config/gcs-service-account.json

# Vercel Blob Storage (Alternative)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token

# Social Media APIs
# Instagram Graph API
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key

# Facebook Graph API
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Monitoring & Analytics
# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Vercel Analytics (Included in Vercel Pro)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id

# Real-time Communication
# Pusher (WebSocket for notifications)
NEXT_PUBLIC_PUSHER_APP_KEY=your_pusher_app_key
PUSHER_APP_ID=your_pusher_app_id
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap3

# Domain Configuration
NEXT_PUBLIC_APP_URL=https://impd.com
NEXT_PUBLIC_SUBDOMAIN_BASE=chopd.impd.com

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
ENABLE_PWA=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_SUBDOMAIN_ROUTING=true

# Environment
NODE_ENV=production

# Optional: Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
